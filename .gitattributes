# Normalize line endings: store everything as LF in the repo.
* text=auto eol=lf

# Explicit text types
*.py      text eol=lf
*.md      text eol=lf
*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.cfg     text eol=lf
*.txt     text eol=lf
*.sql     text eol=lf
*.html    text eol=lf
*.sh      text eol=lf

# Windows scripts keep CRLF
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary — never touch
*.png     binary
*.jpg     binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.db      binary
*.sqlite  binary

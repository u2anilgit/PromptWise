# PromptWise Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# Platform Selection
# ============================================================================
# Which platform to use: mcp (default), codex, gemini, antigravity
PROMPTWISE_PLATFORM=mcp

# ============================================================================
# API Keys
# ============================================================================
# Google Gemini API key
# Get from: https://ai.google.dev/
GEMINI_API_KEY=AIzaSy_your_gemini_key_here

# OpenAI Codex 5.5 API key
# Get from: https://platform.openai.com/api-keys
CODEX_API_KEY=sk-your_codex_key_here

# ============================================================================
# Antigravity CLI (if available)
# ============================================================================
# Endpoint for Antigravity CLI tool
# Formats:
#   - TCP: localhost:5000 or 192.168.1.100:8000
#   - Unix socket: /var/run/antigravity.sock
ANTIGRAVITY_ENDPOINT=localhost:5000

# ============================================================================
# PromptWise Configuration
# ============================================================================
# Log level: DEBUG, INFO (default), WARNING, ERROR
PROMPTWISE_LOG_LEVEL=INFO

# Enable auto-role detection (true/false, default true)
PROMPTWISE_AUTO_ROLE=true

# Auto-role confidence threshold (0.0-1.0, default 0.65)
PROMPTWISE_AUTO_ROLE_THRESHOLD=0.65

# ============================================================================
# Optimization Settings
# ============================================================================
# Compression level: none, light, aggressive
PROMPTWISE_COMPRESSION=light

# Cache strategy: none, selective, aggressive
PROMPTWISE_CACHE_STRATEGY=selective

# Request timeout in seconds (default 30)
PROMPTWISE_TIMEOUT_S=30

# Session budget in USD (optional, for cost limiting)
PROMPTWISE_SESSION_BUDGET=5.00

# ============================================================================
# Development/Debug
# ============================================================================
# Save session history (true/false, default false)
PROMPTWISE_SAVE_HISTORY=false

# History file location
PROMPTWISE_HISTORY_FILE=~/.promptwise/history.db

# Enable detailed metrics (true/false, default false)
PROMPTWISE_DETAILED_METRICS=false

{
  "name": "promptwise-panel",
  "displayName": "PromptWise Panel",
  "description": "Local budget, security, and governance dashboard for PromptWise, over MCP.",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptwise.openPanel",
        "title": "PromptWise: Open Panel"
      }
    ],
    "configuration": {
      "title": "PromptWise",
      "properties": {
        "promptwise.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python interpreter used to launch the PromptWise MCP server."
        },
        "promptwise.workspaceRoot": {
          "type": "string",
          "default": "${workspaceFolder}",
          "description": "Root of the PromptWise checkout. If <root>/src/promptwise exists, PYTHONPATH is set to <root>/src automatically."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "test": "node --test test/*.test.ts",
    "package": "npm run compile && npx vsce package"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "@vscode/vsce": "^3.0.0"
  }
}
